{
  "buildCommand": "npm run build",
  "framework": null,
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/server"
    }
  ],
  "functions": {
    "api/server.js": {
      "includeFiles": "dist/**"
    }
  }
}
